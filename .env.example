# Application
NODE_ENV=development
APP_MODE=local
NEXT_PUBLIC_APP_NAME="My Little Company"
NEXT_PUBLIC_DEMO_MODE=true
DEMO_COMPANY_ID=demo-salon
AUTH_MODE=demo
AUTH_SECRET=replace-with-at-least-32-random-characters
AUTH_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000

# ChatGPT and Codex connector (OAuth + MCP)
MCP_ENABLED=false
# Required when MCP is enabled on HTTPS. Store a JSON-encoded RSA private JWK.
MCP_OAUTH_PRIVATE_JWK=
MCP_OAUTH_KEY_ID=mlc-mcp-1

# Amazon Cognito managed login (required when AUTH_MODE=cognito)
COGNITO_USER_POOL_ID=
COGNITO_REGION=us-east-1
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=
COGNITO_ISSUER=
COGNITO_DOMAIN=
BOOTSTRAP_OWNER_EMAIL=
BOOTSTRAP_OWNER_NAME=

# AWS
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
BEDROCK_KNOWLEDGE_BASE_ID=
BEDROCK_DATA_SOURCE_ID=
BEDROCK_GUARDRAIL_ID=
BEDROCK_GUARDRAIL_VERSION=
DYNAMODB_TABLE_NAME=
S3_BUCKET_NAME=

# Local AWS development should use the AWS credential chain or an AWS profile.
# Do not commit AWS_ACCESS_KEY_ID or AWS_SECRET_ACCESS_KEY.
AWS_PROFILE=

# Optional: Apify website onboarding
APIFY_API_TOKEN=
APIFY_ACTOR_ID=

# Optional: Langfuse telemetry
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=

# Optional: Antitech assessment tooling
ANTITECH_API_KEY=

# Optional: Agora voice onboarding
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
