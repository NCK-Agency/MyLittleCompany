# Application
NODE_ENV=development
APP_MODE=local
NEXT_PUBLIC_APP_NAME="My Little Company"
NEXT_PUBLIC_DEMO_MODE=true
DEMO_COMPANY_ID=demo-salon
AUTH_MODE=demo
AUTH_SECRET=replace-with-at-least-32-random-characters
AUTH_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000
WAITLIST_STORAGE_MODE=local

# Assistant model provider. Local tests use the fixture; hosted AWS persistence
# requires OpenAI and never silently falls back to fixture responses.
MODEL_PROVIDER=fixture
OPENAI_API_KEY=
OPENAI_MODEL_FAST=gpt-5.6-luna
OPENAI_MODEL_BALANCED=gpt-5.6-terra
OPENAI_MODEL_BEST=gpt-5.6-sol

# ChatGPT and Codex connector (OAuth + MCP)
MCP_ENABLED=false
# Required when MCP is enabled on HTTPS. Store a JSON-encoded RSA private JWK.
MCP_OAUTH_PRIVATE_JWK=
MCP_OAUTH_KEY_ID=mlc-mcp-1

# Amazon Cognito managed login at /login (required when AUTH_MODE=cognito).
# The credential-free seeded account picker remains available at /login-demo in demo mode.
COGNITO_USER_POOL_ID=
COGNITO_REGION=us-east-1
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=
COGNITO_ISSUER=
COGNITO_DOMAIN=
BOOTSTRAP_OWNER_EMAIL=
BOOTSTRAP_OWNER_NAME=

# AWS persistence and identity
AWS_REGION=us-east-1
MLC_AWS_REGION=
DYNAMODB_TABLE_NAME=
S3_BUCKET_NAME=

# Local AWS development should use the AWS credential chain or an AWS profile.
# Netlify reserves the standard AWS credential names, so hosted deployments use
# these app-specific non-readable production secrets.
AWS_PROFILE=
MLC_AWS_ACCESS_KEY_ID=
MLC_AWS_SECRET_ACCESS_KEY=

# Optional: Apify website onboarding
APIFY_API_TOKEN=
APIFY_ACTOR_ID=

# Optional: Langfuse telemetry
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=

# Optional: Antitech assessment tooling
ANTITECH_API_KEY=

# Optional: Agora voice onboarding
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
