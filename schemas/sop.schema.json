{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mylittlecompany.local/schemas/sop.schema.json",
  "title": "SOP Draft",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "title",
    "purpose",
    "ownerRole",
    "trigger",
    "prerequisites",
    "steps",
    "qualityChecks",
    "exceptions",
    "escalation",
    "inputs",
    "outputs",
    "assumptions",
    "sourceMemories"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 3,
      "maxLength": 160
    },
    "purpose": {
      "type": "string",
      "minLength": 3,
      "maxLength": 1000
    },
    "ownerRole": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "trigger": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "prerequisites": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 500
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "maxItems": 30,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "order",
          "action",
          "ownerRole",
          "expectedResult"
        ],
        "properties": {
          "order": {
            "type": "integer",
            "minimum": 1
          },
          "action": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          },
          "ownerRole": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "expectedResult": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          }
        }
      }
    },
    "qualityChecks": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 500
      }
    },
    "exceptions": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 500
      }
    },
    "escalation": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 500
      }
    },
    "inputs": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 300
      }
    },
    "outputs": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 300
      }
    },
    "assumptions": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 500
      }
    },
    "sourceMemories": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "memoryId",
          "version"
        ],
        "properties": {
          "memoryId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "version": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    }
  }
}
