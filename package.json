{
  "name": "my-little-company",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "MODEL_PROVIDER=fixture playwright test",
    "test:e2e:hosted": "APP_MODE=aws MODEL_PROVIDER=openai playwright test e2e/salon-demo.spec.ts --workers=1",
    "smoke:openai": "node --env-file-if-exists=.env.local scripts/smoke-openai.mjs",
    "bootstrap:aws-demo": "node scripts/bootstrap-aws-demo.mjs",
    "bootstrap:cognito": "node scripts/bootstrap-cognito-owner.mjs",
    "generate:mcp-key": "node scripts/generate-mcp-oauth-key.mjs",
    "seed:demo": "node scripts/reset-demo.mjs",
    "reset:demo": "node scripts/reset-demo.mjs"
  },
  "dependencies": {
    "@assistant-ui/react": "0.14.26",
    "@assistant-ui/react-markdown": "0.14.5",
    "@aws-sdk/client-cognito-identity-provider": "^3.1085.0",
    "@aws-sdk/client-dynamodb": "^3.1085.0",
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/lib-dynamodb": "^3.1085.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "jose": "^6.2.3",
    "next": "16.2.10",
    "next-auth": "5.0.0-beta.31",
    "openai": "^6.46.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "remark-gfm": "4.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20.19.43",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.5",
    "eslint-config-next": "16.2.10",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
